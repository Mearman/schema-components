{
    "name": "schema-builder-ui",
    "version": "0.0.0",
    "description": "React components for building JSON Schemas visually",
    "type": "module",
    "exports": {
        "./SchemaBuilder": {
            "types": "./dist/SchemaBuilder.d.mts",
            "import": "./dist/SchemaBuilder.mjs"
        },
        "./FieldList": {
            "types": "./dist/FieldList.d.mts",
            "import": "./dist/FieldList.mjs"
        },
        "./FieldRow": {
            "types": "./dist/FieldRow.d.mts",
            "import": "./dist/FieldRow.mjs"
        },
        "./FieldTypePicker": {
            "types": "./dist/FieldTypePicker.d.mts",
            "import": "./dist/FieldTypePicker.mjs"
        },
        "./FieldConfig": {
            "types": "./dist/FieldConfig.d.mts",
            "import": "./dist/FieldConfig.mjs"
        },
        "./SchemaPreview": {
            "types": "./dist/SchemaPreview.d.mts",
            "import": "./dist/SchemaPreview.mjs"
        },
        "./types": {
            "types": "./dist/types.d.mts",
            "import": "./dist/types.mjs"
        },
        "./toJsonSchema": {
            "types": "./dist/toJsonSchema.d.mts",
            "import": "./dist/toJsonSchema.mjs"
        },
        "./styles.css": "./dist/styles.css"
    },
    "files": ["dist", "LICENSE", "README.md"],
    "scripts": {
        "build": "tsdown && cp src/styles.css dist/styles.css",
        "typecheck": "tsc --noEmit",
        "lint": "pnpm exec eslint --cache 'src/**/*.{ts,tsx}'"
    },
    "keywords": [
        "react",
        "json-schema",
        "schema",
        "builder",
        "form-builder",
        "drag-and-drop"
    ],
    "author": "Joseph Mearman",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Mearman/schema-components.git"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "peerDependencies": {
        "@dnd-kit/core": "^6.0.0",
        "@dnd-kit/sortable": "^7.0.0",
        "@dnd-kit/utilities": "^3.0.0",
        "react": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@dnd-kit/core": "6.3.1",
        "@dnd-kit/sortable": "7.0.2",
        "@dnd-kit/utilities": "3.2.2",
        "@types/react": "19.2.14",
        "react": "19.2.6",
        "tsdown": "0.22.0",
        "typescript": "6.0.3"
    }
}
