{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "_typecheck": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "tsconfig.json"],
            "outputs": []
        },
        "_lint": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "eslint.config.ts"],
            "outputs": [".eslintcache"]
        },
        "_lint:fix": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "eslint.config.ts"],
            "outputs": [".eslintcache"],
            "cache": false
        },
        "_test": {
            "dependsOn": ["_typecheck"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "vitest.config.ts"]
        },
        "_test:e2e": {
            "dependsOn": ["_typecheck"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "vitest.config.ts"]
        },
        "_test:coverage": {
            "dependsOn": ["_typecheck"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "vitest.config.ts"]
        },
        "_build": {
            "dependsOn": ["_typecheck", "_lint"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json", "tsdown.config.ts", "package.json"],
            "outputs": ["dist/**"]
        },
        "_typedoc": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "typedoc.json", "../../README.md"],
            "outputs": ["typedoc-static/**"]
        },
        "_check": {
            "dependsOn": ["_typecheck", "_lint", "_build"]
        },
        "_validate": {
            "dependsOn": ["_check", "_test"]
        },
        "build": {
            "dependsOn": ["_build"]
        },
        "check": {
            "dependsOn": ["_check"]
        },
        "validate": {
            "dependsOn": ["_validate"]
        },
        "test": {
            "dependsOn": ["_test"]
        },
        "test:coverage": {
            "dependsOn": ["_test:coverage"]
        },
        "typedoc": {
            "dependsOn": ["_typedoc"]
        },
        "test-storybook": {},
        "build-storybook": {
            "dependsOn": ["^build"],
            "outputs": ["storybook-static/**"]
        }
    }
}
