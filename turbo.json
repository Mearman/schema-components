{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "_typecheck": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "tsconfig.json"],
            "outputs": []
        },
        "_lint": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "eslint.config.ts"],
            "outputs": [".eslintcache"]
        },
        "_lint:fix": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "eslint.config.ts"],
            "outputs": [".eslintcache"],
            "cache": false
        },
        "_test": {
            "dependsOn": ["_typecheck"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "vitest.config.ts"]
        },
        "_test:e2e": {
            "dependsOn": ["_typecheck"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "vitest.config.ts"]
        },
        "_test:preact": {
            "dependsOn": ["_typecheck"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "vitest.config.ts"]
        },
        "_test:vue": {
            "dependsOn": ["_typecheck"],
            "inputs": [
                "src/**/*.ts",
                "src/**/*.tsx",
                "src/**/*.vue",
                "tests/**/*.ts",
                "tests/**/*.tsx",
                "tests/**/*.vue",
                "vitest.config.ts"
            ]
        },
        "_test:svelte": {
            "dependsOn": ["_typecheck"],
            "inputs": [
                "src/**/*.ts",
                "src/**/*.tsx",
                "src/**/*.svelte",
                "tests/**/*.ts",
                "tests/**/*.tsx",
                "tests/**/*.svelte",
                "vitest.config.ts"
            ]
        },
        "_test:solid": {
            "dependsOn": ["_typecheck"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "vitest.config.ts"]
        },
        "_test:lit": {
            "dependsOn": ["_typecheck"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "vitest.config.ts"]
        },
        "_test:coverage": {
            "dependsOn": ["_typecheck"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "vitest.config.ts"]
        },
        "_build": {
            "dependsOn": ["_typecheck", "_lint"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json", "tsdown.config.ts", "package.json"],
            "outputs": ["dist/**"]
        },
        "_typedoc": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "typedoc.json", "../../README.md"],
            "outputs": ["typedoc-static/**"]
        },
        "_api-urls": {
            "dependsOn": ["_typedoc"],
            "inputs": [
                "scripts/build-api-urls.mjs",
                "typedoc-static/project.json"
            ],
            "outputs": ["../docs/src/generated/api-urls.ts"]
        },
        "_check": {
            "dependsOn": ["_typecheck", "_lint", "_build"]
        },
        "_validate": {
            "dependsOn": ["_check", "_test"]
        },
        "build": {
            "dependsOn": ["_build"]
        },
        "check": {
            "dependsOn": ["_check"]
        },
        "validate": {
            "dependsOn": ["_validate"]
        },
        "test": {
            "dependsOn": ["_test"]
        },
        "test:svelte": {
            "dependsOn": ["_test:svelte"]
        },
        "test:solid": {
            "dependsOn": ["_test:solid"]
        },
        "test:lit": {
            "dependsOn": ["_test:lit"]
        },
        "test:coverage": {
            "dependsOn": ["_test:coverage"]
        },
        "typedoc": {
            "dependsOn": ["_typedoc"]
        },
        "api-urls": {
            "dependsOn": ["_api-urls"]
        },
        "test-storybook": {},
        "build-storybook": {
            "dependsOn": ["^build", "^_api-urls"],
            "outputs": ["storybook-static/**"]
        }
    }
}
