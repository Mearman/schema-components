{
    "name": "schema-components-monorepo",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "turbo run build --filter=schema-components",
        "check": "turbo run check --filter=schema-components",
        "validate": "turbo run validate --filter=schema-components",
        "test": "turbo run test --filter=schema-components",
        "test:coverage": "turbo run test:coverage --filter=schema-components",
        "test-storybook": "turbo run test-storybook --filter=@schema-components/docs",
        "storybook": "pnpm --filter @schema-components/docs storybook",
        "build-storybook": "pnpm --filter @schema-components/docs build-storybook",
        "release": "semantic-release",
        "release:dry": "semantic-release --dry-run",
        "prepare": "husky",
        "prepublishOnly": "pnpm validate"
    },
    "devDependencies": {
        "@commitlint/cli": "20.5.3",
        "@commitlint/config-conventional": "20.5.3",
        "@semantic-release/changelog": "6.0.3",
        "@semantic-release/git": "10.0.1",
        "@semantic-release/github": "12.0.6",
        "conventional-changelog-conventionalcommits": "9.3.1",
        "husky": "9.1.7",
        "lint-staged": "17.0.2",
        "semantic-release": "25.0.3",
        "turbo": "2.9.9"
    },
    "packageManager": "pnpm@10.33.1"
}
